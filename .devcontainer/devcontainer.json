{
  "name": "Blitzlord",
  "image": "mcr.microsoft.com/devcontainers/javascript-node:22",
  "postCreateCommand": "npm install -g pnpm && pnpm install",
  "forwardPorts": [3001, 5173],
  "portsAttributes": {
    "3001": { "label": "Server", "onAutoForward": "silent" },
    "5173": { "label": "Client", "onAutoForward": "openBrowser" }
  },
  "customizations": {
    "vscode": {
      "extensions": [
        "bradlc.vscode-tailwindcss",
        "dbaeumer.vscode-eslint"
      ]
    }
  }
}
